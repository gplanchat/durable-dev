{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block toolbar %}
    {% set icon %}
        {{ include('@WebProfiler/Icon/dot.svg') }}
    {% endset %}

    {% set text %}
        <div class="sf-toolbar-info-piece">
            <b>Dispatch Messenger</b>
            <span>{{ collector.dispatchCount }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Workflows (runs)</b>
            <span>{{ collector.workflowCount }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Activités (exécutions)</b>
            <span>{{ collector.activityCount }}</span>
        </div>
    {% endset %}

    {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: 'durable', status: collector.dispatchCount or collector.workflowCount or collector.activityCount ? 'normal' : 'gray', icon: icon }) }}
{% endblock %}

{% block menu %}
    <span class="label">
        <span class="icon">{{ include('@WebProfiler/Icon/dot.svg') }}</span>
        <strong>Durable</strong>
    </span>
    <span class="count">
        <span>{{ collector.dispatchCount }}</span> / <span>{{ collector.workflowCount }}</span> / <span>{{ collector.activityCount }}</span>
    </span>
{% endblock %}

{% block panel %}
    <h2>Durable — dispatch, workflows & activités</h2>

    <p>
        Chronologie des <strong>envois Messenger</strong> de <code>WorkflowRunMessage</code>, des <strong>démarrages / reprises</strong> de workflow
        et des <strong>tentatives d’exécution d’activités</strong> observées pendant cette requête (même processus PHP).
    </p>
    <p class="help">
        En mode <strong>distribué</strong>, les activités et le handler workflow peuvent s’exécuter dans un autre worker : ouvrez le token profiler correspondant au traitement Messenger pour la suite de la trace.
    </p>

    {% if collector.runSnapshots|length > 0 %}
        <h3>État au moment du dispatch (snapshots)</h3>
        <p class="help">Métadonnées workflow et nombre d’événements dans le journal pour chaque <code>executionId</code> vu dans un dispatch.</p>
        <table>
            <thead>
                <tr>
                    <th>executionId</th>
                    <th>Métadonnées</th>
                    <th>Événements (journal)</th>
                </tr>
            </thead>
            <tbody>
                {% for eid, snap in collector.runSnapshots %}
                    <tr>
                        <td><code>{{ eid }}</code></td>
                        <td>
                            {% if snap.metadata is not null %}
                                <strong>{{ snap.metadata.workflowType }}</strong>
                                <pre class="text-muted" style="max-height:120px;overflow:auto">{{ snap.metadata.payload|json_encode(128) }}</pre>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>{{ snap.eventCount }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    {% for executionId, entries in collector.executions %}
        <h3>Exécution <code>{{ executionId }}</code></h3>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Type</th>
                    <th>Détail</th>
                    <th>Durée</th>
                </tr>
            </thead>
            <tbody>
                {% for e in entries %}
                    <tr>
                        <td>{{ e.seq }}</td>
                        <td>
                            {% if e.kind == 'dispatch' %}
                                Dispatch Messenger
                            {% elseif e.kind == 'workflow' %}
                                Workflow {% if e.isResume %}<em>reprise</em>{% else %}<em>démarrage</em>{% endif %}
                            {% elseif e.kind == 'activity' %}
                                Activité
                            {% else %}
                                {{ e.kind|default('?') }}
                            {% endif %}
                        </td>
                        <td>
                            {% if e.kind == 'dispatch' %}
                                <strong>{{ e.workflowType|default('') }}</strong>
                                {% if e.isResume %}<span class="text-muted">(reprise)</span>{% endif %}
                                {% if e.transportNames is defined and e.transportNames %}
                                    <br><span class="text-muted">transports : {{ e.transportNames }}</span>
                                {% endif %}
                                <pre class="text-muted" style="max-height:100px;overflow:auto">{{ e.payload|default({})|json_encode(128) }}</pre>
                            {% elseif e.kind == 'workflow' %}
                                {{ e.workflowType }}
                            {% elseif e.kind == 'activity' %}
                                <strong>{{ e.activityName }}</strong>
                                <span class="text-muted">({{ e.activityId }})</span>
                                {% if not e.success %}
                                    <br><span class="status-error">{{ e.errorClass|default('') }}</span>
                                {% endif %}
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>
                            {% if e.kind == 'activity' %}
                                {{ (e.durationSeconds * 1000)|number_format(2) }} ms
                            {% else %}
                                —
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        {% if collector.timeline|length == 0 %}
            <p class="help">Aucun événement Durable sur cette requête.</p>
        {% endif %}
    {% endfor %}

    {% if collector.timeline|length > 0 %}
        <h3>Ordre global (tous executionId)</h3>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>executionId</th>
                    <th>Événement</th>
                </tr>
            </thead>
            <tbody>
                {% for e in collector.timeline %}
                    <tr>
                        <td>{{ e.seq }}</td>
                        <td><code>{{ e.executionId|default('') }}</code></td>
                        <td>
                            {% if e.kind == 'dispatch' %}
                                dispatch {{ e.workflowType|default('') }}
                                {% if e.transportNames %} [{{ e.transportNames }}]{% endif %}
                            {% elseif e.kind == 'workflow' %}
                                workflow {{ e.workflowType }} {% if e.isResume %}(reprise){% else %}(démarrage){% endif %}
                            {% elseif e.kind == 'activity' %}
                                {{ e.activityName }} — {{ (e.durationSeconds * 1000)|number_format(2) }} ms
                                {% if not e.success %} ({{ e.errorClass }}){% endif %}
                            {% else %}
                                {{ e.kind|default('') }}
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
