<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="durable_events" resource="default" engine="innodb" comment="Durable event journal">
        <column xsi:type="bigint" name="id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="execution_id" nullable="false" length="36" comment="Execution UUID"/>
        <column xsi:type="varchar" name="event_type" nullable="false" length="255" comment="Event class short name"/>
        <column xsi:type="text" name="payload" nullable="false" comment="JSON payload"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <index referenceId="DURABLE_EVENTS_EXECUTION_ID" indexType="btree">
            <column name="execution_id"/>
        </index>
    </table>
    <table name="durable_workflow_metadata" resource="default" engine="innodb" comment="Durable workflow resume metadata">
        <column xsi:type="varchar" name="execution_id" nullable="false" length="36" comment="Execution UUID"/>
        <column xsi:type="varchar" name="workflow_type" nullable="false" length="255" comment="Workflow type"/>
        <column xsi:type="text" name="payload" nullable="false" comment="JSON payload"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="execution_id"/>
        </constraint>
    </table>
    <table name="durable_child_workflow_parent_link" resource="default" engine="innodb" comment="Durable async child workflow parent link">
        <column xsi:type="varchar" name="child_execution_id" nullable="false" length="255" comment="Child execution id"/>
        <column xsi:type="varchar" name="parent_execution_id" nullable="false" length="255" comment="Parent execution id"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="child_execution_id"/>
        </constraint>
    </table>
    <table name="durable_activity_outbox" resource="default" engine="innodb" comment="Durable activity queue (DBAL transport)">
        <column xsi:type="bigint" name="id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="execution_id" nullable="false" length="36" comment="Execution UUID"/>
        <column xsi:type="varchar" name="activity_id" nullable="false" length="36" comment="Activity id"/>
        <column xsi:type="varchar" name="activity_name" nullable="false" length="255" comment="Activity name"/>
        <column xsi:type="text" name="payload" nullable="false" comment="JSON payload"/>
        <column xsi:type="text" name="metadata" nullable="false" comment="JSON metadata"/>
        <column xsi:type="decimal" name="available_at" nullable="true" precision="24" scale="6" comment="Scheduled time (microtime as decimal)"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <index referenceId="DURABLE_ACTIVITY_OUTBOX_EXECUTION_ID" indexType="btree">
            <column name="execution_id"/>
        </index>
    </table>
</schema>
