{
    "name": "gplanchat/durable-monorepo",
    "description": "Monorepo root: gplanchat/durable + bridge + bundle (dev tooling only).",
    "license": "proprietary",
    "type": "project",
    "version": "0.1.0",
    "repositories": [
        {"type": "path", "url": "src/Durable"},
        {"type": "path", "url": "src/DurableBundle"},
        {"type": "path", "url": "src/Bridge/Temporal"}
    ],
    "require": {
        "php": ">=8.2",
        "gplanchat/durable": "@dev",
        "gplanchat/durable-bundle": "@dev",
        "gplanchat/durable-bridge-temporal": "@dev",
        "doctrine/dbal": "^4.4",
        "psr/clock": "^1.0",
        "psr/log": "^3.0",
        "symfony/uid": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/config": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/console": "^7.0",
        "google/common-protos": "^4.9",
        "google/protobuf": "^4.31",
        "grpc/grpc": "^1.57"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Gplanchat\\Durable\\": "src/Durable/",
            "Gplanchat\\Durable\\Bundle\\": "src/DurableBundle/",
            "Gplanchat\\Bridge\\Temporal\\": "src/Bridge/Temporal/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "unit\\": "tests/unit/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-text",
        "cs:check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs:fix": "vendor/bin/php-cs-fixer fix",
        "phpstan": "vendor/bin/phpstan analyse",
        "psalm": "vendor/bin/psalm"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "authors": [
        {
            "name": "Grégory Planchat",
            "email": "gregory@gyroscops.com"
        }
    ]
}
