{
    "name": "gplanchat/durable",
    "description": "Monorepo: gplanchat/durable (src/Durable), gplanchat/durable-bundle (src/DurableBundle), bridge Temporal (src/Bridge/Temporal), outils d’analyse (src/DurablePhpStan, src/DurablePsalmPlugin) — source unique ; publication par splitsh.",
    "license": "proprietary",
    "version": "0.1.0",
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "require": {
        "php": ">=8.2",
        "psr/clock": "^1.0",
        "psr/log": "^3.0",
        "symfony/uid": "^6.4 || ^7.4",
        "doctrine/dbal": "^4.4",
        "symfony/messenger": "^6.4 || ^7.4",
        "symfony/contracts": "^3.5",
        "symfony/framework-bundle": "^6.4 || ^7.4",
        "symfony/dependency-injection": "^6.4 || ^7.4",
        "symfony/config": "^6.4 || ^7.4",
        "symfony/routing": "^6.4 || ^7.4",
        "symfony/console": "^6.4 || ^7.4",
        "google/common-protos": "^4.9",
        "google/protobuf": "^4.31",
        "grpc/grpc": "^1.57",
        "roadrunner-php/roadrunner-api-dto": "^1.14"
    },
    "suggest": {
        "ext-pcov": "For composer test:coverage and Infection (mutation testing); sinon Xdebug (mode coverage) ou phpdbg -qrr vendor/bin/infection",
        "gplanchat/durable-phpstan": "Optional PHPStan extension for ActivityStub + Awaitable (src/DurablePhpStan; see ADR012)",
        "gplanchat/durable-psalm-plugin": "Optional Psalm plugin entry point; prefer durable-phpstan for ActivityStub typing (ADR012)"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "vimeo/psalm": "^6.0",
        "infection/infection": "^0.29"
    },
    "autoload": {
        "psr-4": {
            "Gplanchat\\Durable\\": "src/Durable/",
            "Gplanchat\\Durable\\Bundle\\": "src/DurableBundle/",
            "Gplanchat\\Bridge\\Temporal\\": "src/Bridge/Temporal/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "unit\\Gplanchat\\": "tests/unit/",
            "functional\\Gplanchat\\": "tests/functional/",
            "integration\\Gplanchat\\": "tests/integration/",
            "e2e\\Gplanchat\\": "tests/e2e/",
            "Gplanchat\\Durable\\PHPStan\\": "src/DurablePhpStan/src/",
            "Gplanchat\\Durable\\Psalm\\": "src/DurablePsalmPlugin/src/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix --diff",
        "cs:check": "php-cs-fixer fix --diff --dry-run",
        "test": "phpunit --strict-coverage",
        "test:coverage": "phpunit --strict-coverage --coverage-text --coverage-filter=src/Durable --coverage-filter=src/DurableBundle --coverage-filter=src/Bridge/Temporal",
        "phpstan": "@php vendor/bin/phpstan analyse --memory-limit=512M",
        "psalm": "@php vendor/bin/psalm",
        "infection": "@php vendor/bin/infection -c infection.json.dist --threads=max",
        "infection:unit": "@php vendor/bin/infection -c infection.json.dist --threads=max --test-framework-options=\"--testsuite=unit\"",
        "infection:functional": "@php vendor/bin/infection -c infection.json.dist --threads=max --test-framework-options=\"--testsuite=functional\"",
        "infection:unit-fast": "@php vendor/bin/infection -c infection.json.dist --threads=max --only-covered --test-framework-options=\"--testsuite=unit\""
    },
    "authors": [
        {
            "name": "Grégory Planchat",
            "email": "gregory@gyroscops.com"
        }
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "archive": {
        "exclude": [
            "/.cursor",
            "/var",
            "/vendor",
            "/symfony",
            "/tests",
            "/phpunit.xml.dist",
            "/.php-cs-fixer.dist.php"
        ]
    }
}
