# Analyse du monorepo (src/ + tests/) avec l’extension ActivityStub (ADR012).
includes:
    - src/DurablePhpStan/extension.neon

parameters:
    level: 6
    ignoreErrors:
        -
            identifier: missingType.generics
            path: src/Bridge/Temporal/Grpc/GrpcUnary.php
    paths:
        - src/Durable
        - src/DurableBundle
        - src/Bridge/Temporal
        - tests
