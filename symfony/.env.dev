###< symfony/framework-bundle ###

###> symfony/messenger + gplanchat/durable-bridge-temporal ###
# Connexion Temporal (journal) : sans inner — alimente TemporalJournalEventStore (workflows DurableJournal dans l’UI).
# Même hôte/port que TEMPORAL_FRONTEND_PORT (.env). Exige ext-grpc en local.
DURABLE_TEMPORAL_DSN=temporal://127.0.0.1:7234?namespace=default&journal_task_queue=durable-journal&tls=0
#
# Files Messenger : enveloppe temporal:// + inner Doctrine (les messages restent en tables SQLite, pas en activités Temporal).
# Le port doit coïncider avec TEMPORAL_FRONTEND_PORT dans .env.
MESSENGER_DURABLE_WORKFLOW_DSN=temporal://127.0.0.1:7234?namespace=default&inner=doctrine%3A%2F%2Fdefault%3Fqueue_name%3Ddurable_workflows%26auto_setup%3Dtrue
MESSENGER_DURABLE_ACTIVITY_DSN=temporal://127.0.0.1:7234?namespace=default&inner=doctrine%3A%2F%2Fdefault%3Fqueue_name%3Ddurable_activities%26auto_setup%3Dtrue
###< symfony/messenger + gplanchat/durable-bridge-temporal ###
