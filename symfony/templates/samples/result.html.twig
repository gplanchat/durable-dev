{% extends 'base.html.twig' %}

{% block title %}{{ scenario.label }} — Durable{% endblock %}

{% block body %}
<div class="container-sm">
    <div style="margin-bottom: 1.5rem;">
        <a href="{{ path('durable_samples_index') }}" class="back-link">← Retour aux samples</a>
    </div>

    <div class="page-intro">
        <h1>{{ scenario.label }}</h1>
        <p>{{ scenario.description }}</p>
    </div>

    <div class="stack">
        <div class="result-card">
            <div class="result-card-header">Exécution</div>
            <div class="result-card-body">
                <dl class="meta-list">
                    <dt>Type</dt>
                    <dd><code>{{ scenario.workflowType }}</code></dd>
                    <dt>executionId</dt>
                    <dd><code>{{ executionId }}</code></dd>
                    <dt>Mode</dt>
                    <dd>
                        {% if waitedForCompletion %}
                            ▶ Synchrone — résultat disponible
                        {% else %}
                            ⚡ Async — fire &amp; forget
                        {% endif %}
                    </dd>
                </dl>
            </div>
        </div>

        {% if waitedForCompletion %}
            <div class="result-card">
                <div class="result-card-header">Résultat</div>
                <div class="result-card-body">
                    <pre>{% if result is iterable %}{{ result|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}{% else %}{{ result }}{% endif %}</pre>
                </div>
            </div>
        {% else %}
            <div class="alert alert-info">
                Workflow dispatché en mode async. Lancez des workers pour l'exécution :
                <br><code>php bin/console messenger:consume durable_workflows durable_activities</code>
                <br>Pour suivre le journal dans le profiler : <code>?durable_execution={{ executionId }}</code>
            </div>
        {% endif %}

        {% if scenario.defaultPayload is not empty %}
            <div class="result-card">
                <div class="result-card-header">Payload</div>
                <div class="result-card-body">
                    <pre>{{ scenario.defaultPayload|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                </div>
            </div>
        {% endif %}

        <div class="hstack">
            <a href="{{ path('durable_samples_run', { id: scenario.id }) }}" class="btn btn-primary">▶ Relancer (sync)</a>
            <a href="{{ path('durable_samples_run', { id: scenario.id, wait: '0' }) }}" class="btn btn-ghost">⚡ Relancer (async)</a>
            <a href="{{ path('durable_samples_index') }}" class="btn btn-ghost btn-sm" style="margin-left: auto;">← Tous les samples</a>
        </div>
    </div>
</div>
{% endblock %}
