<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Durable{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    <style>
        :root {
            --c-bg: #f6f7f9;
            --c-surface: #ffffff;
            --c-border: #e2e8f0;
            --c-text: #1e293b;
            --c-muted: #64748b;
            --c-primary: #1e293b;
            --c-primary-hover: #0f172a;
            --c-accent: #2563eb;
            --c-accent-hover: #1d4ed8;
            --c-success: #16a34a;
            --c-danger: #dc2626;
            --shadow-sm: 0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
            --shadow-md: 0 4px 8px -2px rgba(0,0,0,.1), 0 2px 4px -1px rgba(0,0,0,.06);
            --radius: 8px;
            --font: system-ui, -apple-system, 'Segoe UI', sans-serif;
            --font-mono: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font);
            background: var(--c-bg);
            color: var(--c-text);
            line-height: 1.6;
            min-height: 100vh;
        }

        a { color: var(--c-accent); text-decoration: none; }
        a:hover { color: var(--c-accent-hover); text-decoration: underline; }

        h1 { font-size: 1.65rem; font-weight: 700; line-height: 1.2; }
        h2 { font-size: 1.2rem; font-weight: 600; }
        h3 { font-size: 0.975rem; font-weight: 600; }

        code {
            font-family: var(--font-mono);
            font-size: 0.85em;
            background: #f1f5f9;
            padding: 0.15em 0.45em;
            border-radius: 4px;
            color: #0f172a;
            border: 1px solid #e2e8f0;
        }

        pre {
            font-family: var(--font-mono);
            font-size: 0.85rem;
            background: #f8fafc;
            border: 1px solid var(--c-border);
            padding: 1rem 1.25rem;
            border-radius: var(--radius);
            overflow: auto;
            color: #0f172a;
            line-height: 1.65;
        }
        pre code { background: none; padding: 0; border: none; font-size: inherit; }

        hr { border: none; border-top: 1px solid var(--c-border); margin: 2rem 0; }

        /* ── Navigation ─────────────────────────────── */
        .site-nav {
            background: var(--c-primary);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            height: 52px;
            gap: 1.75rem;
        }
        .nav-brand {
            font-weight: 700;
            font-size: 0.95rem;
            color: #fff !important;
            text-decoration: none !important;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            letter-spacing: -0.01em;
        }
        .nav-brand .nav-sub {
            opacity: 0.55;
            font-weight: 400;
            font-size: 0.82rem;
        }
        .site-nav a:not(.nav-brand) {
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 0.875rem;
        }
        .site-nav a:not(.nav-brand):hover { color: #fff; text-decoration: none; }
        .nav-spacer { flex: 1; }

        /* ── Layout containers ──────────────────────── */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }
        .container-sm {
            max-width: 660px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        /* ── Card grid ──────────────────────────────── */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.25rem;
        }

        .card {
            background: var(--c-surface);
            border: 1px solid var(--c-border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
            transition: box-shadow 0.15s, transform 0.1s;
        }
        .card:hover { box-shadow: var(--shadow-md); }

        .card-header {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            flex-wrap: wrap;
        }
        .card-title { font-size: 0.95rem; font-weight: 600; color: var(--c-text); }
        .card-badge {
            font-family: var(--font-mono);
            font-size: 0.72rem;
            color: var(--c-muted);
            background: #f1f5f9;
            border: 1px solid #e2e8f0;
            padding: 0.1em 0.55em;
            border-radius: 4px;
        }
        .card-description {
            font-size: 0.875rem;
            color: var(--c-muted);
            flex-grow: 1;
            line-height: 1.5;
        }
        .card-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            padding-top: 0.25rem;
        }

        /* ── Buttons ────────────────────────────────── */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.45rem 0.95rem;
            border-radius: 6px;
            text-decoration: none !important;
            font-size: 0.85rem;
            font-weight: 500;
            line-height: 1.4;
            transition: background 0.12s, color 0.12s, border-color 0.12s;
            white-space: nowrap;
            cursor: pointer;
        }
        .btn-primary {
            background: var(--c-primary);
            color: #fff !important;
        }
        .btn-primary:hover { background: var(--c-primary-hover); }

        .btn-ghost {
            background: transparent;
            color: var(--c-muted) !important;
            border: 1px solid var(--c-border);
        }
        .btn-ghost:hover { background: #f1f5f9; color: var(--c-text) !important; border-color: #cbd5e1; }

        .btn-sm { padding: 0.3rem 0.65rem; font-size: 0.8rem; }

        /* ── Alerts ─────────────────────────────────── */
        .alert {
            padding: 0.9rem 1.1rem;
            border-radius: var(--radius);
            font-size: 0.9rem;
            line-height: 1.55;
        }
        .alert-info    { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }
        .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }
        .alert-warning { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; }
        .alert-danger  { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; }
        .alert code { background: rgba(0,0,0,.06); border-color: transparent; }

        /* ── Result card ────────────────────────────── */
        .result-card {
            background: var(--c-surface);
            border: 1px solid var(--c-border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }
        .result-card-header {
            background: #f8fafc;
            border-bottom: 1px solid var(--c-border);
            padding: 0.6rem 1.1rem;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: var(--c-muted);
        }
        .result-card-body { padding: 1.1rem 1.25rem; }

        /* ── Meta list (key/value) ──────────────────── */
        .meta-list {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 0.4rem 1.25rem;
            font-size: 0.9rem;
            align-items: baseline;
        }
        .meta-list dt { font-weight: 600; color: var(--c-muted); white-space: nowrap; }
        .meta-list dd { margin: 0; word-break: break-all; }

        /* ── Page intro ─────────────────────────────── */
        .page-intro { margin-bottom: 2rem; }
        .page-intro h1 { margin-bottom: 0.5rem; }
        .page-intro p {
            color: var(--c-muted);
            font-size: 0.95rem;
            margin-top: 0.4rem;
            max-width: 64ch;
        }

        /* ── Flex helpers ───────────────────────────── */
        .stack  { display: flex; flex-direction: column; gap: 1rem; }
        .hstack { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }

        /* ── Back link ──────────────────────────────── */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: var(--c-muted) !important;
            font-size: 0.875rem;
            text-decoration: none !important;
        }
        .back-link:hover { color: var(--c-text) !important; }

        /* ── Steps list ─────────────────────────────── */
        .steps ol {
            padding-left: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.55rem;
        }
        .steps li { font-size: 0.9rem; color: var(--c-muted); line-height: 1.55; }
        .steps li strong { color: var(--c-text); }
    </style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
    <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
    <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
    <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body>
    <nav class="site-nav">
        <a class="nav-brand" href="{{ path('durable_home') }}">
            ⚙ Durable <span class="nav-sub">for Symfony</span>
        </a>
        <a href="{{ path('durable_home') }}">Samples</a>
    </nav>
    {% block body %}{% endblock %}
</body>
</html>
