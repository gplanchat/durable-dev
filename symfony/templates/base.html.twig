<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Durable{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    <style>
        :root {
            --ds-bg: #1f1633;
            --ds-bg-deep: #150f23;
            --ds-surface: #241a3d;
            --ds-surface-alt: #2c2250;
            --ds-border: #362d59;
            --ds-border-soft: #584674;
            --ds-text: #ffffff;
            --ds-text-muted: #d2cae3;
            --ds-primary: #79628c;
            --ds-primary-hover: #6a5fc1;
            --ds-accent: #c2ef4e;
            --ds-danger: #fa7faa;
            --ds-success: #c2ef4e;
            --ds-warning: #ffb287;
            --shadow-sm: rgba(0, 0, 0, 0.1) 0 1px 3px 0 inset;
            --shadow-md: rgba(0, 0, 0, 0.18) 0 0.5rem 1.5rem;
            --radius: 10px;
            --font: "Rubik", -apple-system, system-ui, "Segoe UI", Helvetica, Arial, sans-serif;
            --font-mono: "Monaco", "Menlo", "Ubuntu Mono", ui-monospace, monospace;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: var(--font);
            background: linear-gradient(160deg, var(--ds-bg) 0%, var(--ds-bg-deep) 100%);
            color: var(--ds-text);
            line-height: 1.55;
            min-height: 100vh;
        }

        a { color: var(--ds-primary-hover); text-decoration: underline; text-underline-offset: 0.2em; }
        a:hover { color: var(--ds-accent); }

        h1 { font-size: 1.9rem; font-weight: 600; line-height: 1.2; }
        h2 { font-size: 1.4rem; font-weight: 500; line-height: 1.2; }
        h3 { font-size: 1.1rem; font-weight: 500; line-height: 1.25; }

        code {
            font-family: var(--font-mono);
            font-size: 0.86em;
            background: rgba(255, 255, 255, 0.08);
            padding: 0.16em 0.42em;
            border-radius: 4px;
            color: #dcdcaa;
            border: 1px solid var(--ds-border);
        }

        pre {
            font-family: var(--font-mono);
            font-size: 0.86rem;
            background: rgba(21, 15, 35, 0.82);
            border: 1px solid var(--ds-border);
            padding: 1rem 1.25rem;
            border-radius: var(--radius);
            overflow: auto;
            color: var(--ds-text-muted);
            line-height: 1.65;
        }
        pre code { background: none; padding: 0; border: none; }

        hr { border: none; border-top: 1px solid var(--ds-border); margin: 2rem 0; }

        .site-nav {
            background: rgba(21, 15, 35, 0.88);
            border-bottom: 1px solid var(--ds-border);
            backdrop-filter: blur(18px) saturate(180%);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            height: 56px;
            gap: 1rem;
        }
        .nav-brand {
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--ds-text) !important;
            text-decoration: none !important;
            display: inline-flex;
            align-items: center;
            gap: 0.42rem;
        }
        .nav-brand .nav-sub {
            opacity: 0.75;
            font-weight: 400;
            font-size: 0.82rem;
        }
        .site-nav a:not(.nav-brand) {
            color: var(--ds-text-muted);
            text-decoration: none;
            font-size: 0.84rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-weight: 500;
        }
        .site-nav a:not(.nav-brand):hover { color: var(--ds-accent); }
        .nav-spacer { flex: 1; }

        .container {
            max-width: 1152px;
            margin: 0 auto;
            padding: 2rem 1.5rem 2.5rem;
        }
        .container-sm {
            max-width: 760px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1rem;
        }

        .card {
            background: var(--ds-surface);
            border: 1px solid var(--ds-border);
            border-radius: 12px;
            padding: 1rem;
            box-shadow: rgba(0, 0, 0, 0.1) 0 10px 15px -3px;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }
        .card-header { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
        .card-title { color: var(--ds-text); font-size: 1rem; font-weight: 600; }
        .card-badge {
            font-family: var(--font-mono);
            font-size: 0.72rem;
            color: var(--ds-text-muted);
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid var(--ds-border);
            padding: 0.1em 0.55em;
            border-radius: 6px;
        }
        .card-description { color: var(--ds-text-muted); font-size: 0.9rem; line-height: 1.5; }
        .card-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 0.2rem; }

        .btn,
        .ds-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            padding: 0.5rem 0.95rem;
            border-radius: 13px;
            text-decoration: none !important;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            transition: box-shadow 0.15s ease, background-color 0.15s ease, color 0.15s ease;
            border: 1px solid transparent;
            cursor: pointer;
        }

        .btn-primary,
        .ds-btn--primary {
            background: var(--ds-primary);
            border-color: var(--ds-border-soft);
            box-shadow: var(--shadow-sm);
            color: var(--ds-text) !important;
        }
        .btn-primary:hover,
        .ds-btn--primary:hover {
            background: var(--ds-primary-hover);
            box-shadow: var(--shadow-md);
            color: var(--ds-text) !important;
        }

        .btn-ghost,
        .ds-btn--ghost {
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--ds-border);
            color: var(--ds-text-muted) !important;
        }
        .btn-ghost:hover,
        .ds-btn--ghost:hover {
            background: rgba(54, 22, 107, 0.14);
            color: var(--ds-text) !important;
            box-shadow: rgba(0, 0, 0, 0.08) 0 2px 8px;
        }
        .btn-sm { padding: 0.35rem 0.65rem; font-size: 0.74rem; }

        .alert {
            padding: 0.9rem 1.1rem;
            border-radius: var(--radius);
            font-size: 0.9rem;
            line-height: 1.55;
            border: 1px solid var(--ds-border);
        }
        .alert-info { background: rgba(106, 95, 193, 0.15); color: var(--ds-text); }
        .alert-success { background: rgba(194, 239, 78, 0.12); color: var(--ds-text); }
        .alert-warning { background: rgba(255, 178, 135, 0.15); color: var(--ds-text); }
        .alert-danger { background: rgba(250, 127, 170, 0.17); color: var(--ds-text); }
        .alert code { background: rgba(255, 255, 255, 0.09); border-color: transparent; }

        .result-card {
            background: var(--ds-surface);
            border: 1px solid var(--ds-border);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: rgba(0, 0, 0, 0.1) 0 10px 15px -3px;
        }
        .result-card-header {
            background: rgba(255, 255, 255, 0.06);
            border-bottom: 1px solid var(--ds-border);
            padding: 0.65rem 1rem;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--ds-text-muted);
        }
        .result-card-body { padding: 1rem; }

        .meta-list {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 0.35rem 1rem;
            font-size: 0.9rem;
            align-items: baseline;
        }
        .meta-list dt { font-weight: 600; color: var(--ds-text-muted); }
        .meta-list dd { margin: 0; color: var(--ds-text); word-break: break-all; }

        .page-intro { margin-bottom: 1.5rem; }
        .page-intro h1 { margin-bottom: 0.45rem; }
        .page-intro p { color: var(--ds-text-muted); max-width: 72ch; }

        .stack { display: flex; flex-direction: column; gap: 1rem; }
        .hstack { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: var(--ds-text-muted) !important;
            font-size: 0.85rem;
            text-decoration: none !important;
        }
        .back-link:hover { color: var(--ds-accent) !important; }

        .steps ol {
            padding-left: 1.35rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .steps li { color: var(--ds-text-muted); font-size: 0.9rem; }
        .steps li strong { color: var(--ds-text); }

        .ds-page { display: flex; flex-direction: column; gap: 1rem; }
        .ds-kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.75rem;
        }
        .ds-kpi {
            background: var(--ds-surface);
            border: 1px solid var(--ds-border);
            border-radius: 12px;
            padding: 0.8rem 1rem;
        }
        .ds-kpi__label {
            display: block;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--ds-text-muted);
            margin-bottom: 0.35rem;
        }
        .ds-kpi__value { font-size: 1.45rem; line-height: 1.2; }

        .ds-filters {
            display: grid;
            grid-template-columns: minmax(220px, 1fr) minmax(170px, 220px) auto;
            gap: 0.75rem;
            align-items: end;
            background: var(--ds-surface);
            border: 1px solid var(--ds-border);
            border-radius: 12px;
            padding: 0.85rem;
        }
        .ds-filters label {
            display: block;
            color: var(--ds-text-muted);
            font-size: 0.74rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 0.35rem;
        }
        .ds-input,
        .ds-select {
            width: 100%;
            background: #ffffff;
            border: 1px solid #cfcfdb;
            color: #1f1633;
            border-radius: 6px;
            padding: 0.5rem 0.6rem;
            font: inherit;
        }
        .ds-input:focus,
        .ds-select:focus {
            outline: 2px solid var(--ds-primary-hover);
            outline-offset: 1px;
        }

        .ds-dashboard-split {
            display: grid;
            grid-template-columns: minmax(260px, 36%) 1fr;
            gap: 1rem;
            align-items: start;
        }
        .ds-dashboard-list,
        .ds-dashboard-detail {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        .ds-pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.75rem;
            padding: 0.65rem 0.75rem;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--ds-border);
            border-radius: 10px;
            flex-wrap: wrap;
        }
        .ds-pagination__label {
            color: var(--ds-text-muted);
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }
        .ds-pagination__disabled {
            display: inline-flex;
            align-items: center;
            padding: 0.35rem 0.65rem;
            border-radius: 13px;
            border: 1px solid var(--ds-border);
            color: rgba(210, 202, 227, 0.55);
            font-size: 0.74rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            font-weight: 700;
        }
        .ds-pagination__cursor {
            color: var(--ds-text-muted);
            font-size: 0.76rem;
        }
        .ds-run-row {
            text-decoration: none !important;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            background: var(--ds-surface);
            border: 1px solid var(--ds-border);
            border-radius: 10px;
            padding: 0.75rem;
            color: var(--ds-text);
        }
        .ds-run-row:hover { border-color: var(--ds-primary-hover); }
        .ds-run-row.is-active {
            border-color: var(--ds-primary-hover);
            box-shadow: inset 0 0 0 1px rgba(106, 95, 193, 0.45);
        }
        .ds-run-row__title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.6rem;
            font-size: 0.95rem;
            font-weight: 600;
        }
        .ds-run-row__meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem 0.7rem;
            font-size: 0.78rem;
            color: var(--ds-text-muted);
        }
        .ds-mono { font-family: var(--font-mono); }

        .ds-status-badge {
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 0.18rem 0.45rem;
            border-radius: 999px;
            border: 1px solid var(--ds-border);
        }
        .ds-status-badge--running {
            color: var(--ds-text);
            background: rgba(106, 95, 193, 0.2);
            border-color: var(--ds-primary-hover);
        }
        .ds-status-badge--completed {
            color: #0f1a00;
            background: rgba(194, 239, 78, 0.95);
            border-color: rgba(194, 239, 78, 0.95);
        }
        .ds-status-badge--failed {
            color: var(--ds-text);
            background: rgba(250, 127, 170, 0.2);
            border-color: rgba(250, 127, 170, 0.55);
        }

        .ds-event-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        .ds-event {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem 0.9rem;
            align-items: center;
            padding: 0.55rem 0.65rem;
            border: 1px solid var(--ds-border);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.04);
        }
        .ds-event__time {
            color: var(--ds-text-muted);
            font-size: 0.78rem;
            min-width: 64px;
        }
        .ds-empty-state {
            color: var(--ds-text-muted);
            font-size: 0.9rem;
            padding: 0.6rem 0.2rem;
        }
        .ds-timeline {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        .ds-timeline__item {
            display: grid;
            grid-template-columns: 14px 1fr;
            gap: 0.6rem;
            align-items: start;
            position: relative;
        }
        .ds-timeline__item::before {
            content: "";
            position: absolute;
            left: 6px;
            top: 14px;
            bottom: -12px;
            width: 2px;
            background: rgba(121, 98, 140, 0.6);
        }
        .ds-timeline__item:last-child::before {
            display: none;
        }
        .ds-timeline__dot {
            width: 12px;
            height: 12px;
            border-radius: 999px;
            border: 2px solid var(--ds-primary-hover);
            background: var(--ds-bg);
            margin-top: 3px;
        }
        .ds-timeline__content {
            border: 1px solid var(--ds-border);
            background: rgba(255, 255, 255, 0.04);
            border-radius: 8px;
            padding: 0.5rem 0.6rem;
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }
        .ds-timeline__meta {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            color: var(--ds-text-muted);
            font-size: 0.77rem;
        }
        .ds-event__id {
            font-family: var(--font-mono);
            color: rgba(194, 239, 78, 0.85);
        }
        .ds-event-kind {
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            border: 1px solid var(--ds-border);
            padding: 0.12rem 0.42rem;
            font-size: 0.62rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }
        .ds-event-kind--workflow {
            background: rgba(106, 95, 193, 0.2);
            border-color: rgba(106, 95, 193, 0.6);
            color: #e9e5ff;
        }
        .ds-event-kind--activity {
            background: rgba(194, 239, 78, 0.22);
            border-color: rgba(194, 239, 78, 0.65);
            color: #101c00;
        }
        .ds-event-kind--timer {
            background: rgba(255, 178, 135, 0.2);
            border-color: rgba(255, 178, 135, 0.65);
            color: #fff0e7;
        }
        .ds-event-kind--signal {
            background: rgba(250, 127, 170, 0.2);
            border-color: rgba(250, 127, 170, 0.65);
            color: #ffeaf2;
        }
        .ds-event-kind--child {
            background: rgba(149, 203, 255, 0.2);
            border-color: rgba(149, 203, 255, 0.65);
            color: #e8f5ff;
        }
        .ds-event-kind--marker,
        .ds-event-kind--other {
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(255, 255, 255, 0.35);
            color: var(--ds-text-muted);
        }

        .hero {
            background: linear-gradient(140deg, rgba(36, 26, 61, 0.95), rgba(21, 15, 35, 0.95));
            border: 1px solid var(--ds-border);
            border-radius: 12px;
            padding: 1.25rem;
            margin-bottom: 1.25rem;
            box-shadow: rgba(22, 15, 36, 0.9) 0 4px 4px 9px;
            display: flex;
            flex-direction: column;
            gap: 0.85rem;
        }
        .hero__label {
            display: inline-flex;
            align-self: flex-start;
            background: rgba(194, 239, 78, 0.15);
            color: var(--ds-accent);
            border: 1px solid rgba(194, 239, 78, 0.45);
            border-radius: 999px;
            padding: 0.2rem 0.55rem;
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }
        .hero p {
            color: var(--ds-text-muted);
            max-width: 68ch;
        }
        .hero__points {
            margin: 0;
            padding-left: 1.05rem;
            display: grid;
            gap: 0.4rem;
        }
        .hero__points li {
            color: var(--ds-text-muted);
            line-height: 1.45;
            font-size: 0.9rem;
        }

        @media (max-width: 940px) {
            .ds-filters {
                grid-template-columns: 1fr;
            }
            .ds-dashboard-split {
                grid-template-columns: 1fr;
            }
        }
    </style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
    <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
    <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
    <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body>
    <nav class="site-nav">
        <a class="nav-brand" href="{{ path('durable_home') }}">
            ⚙ Durable <span class="nav-sub">for Symfony</span>
        </a>
        <a href="{{ path('durable_home') }}">Samples</a>
        <a href="{{ path('app_dashboard') }}">Dashboard</a>
    </nav>
    {% block body %}{% endblock %}
</body>
</html>
