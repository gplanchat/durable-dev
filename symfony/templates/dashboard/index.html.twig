{% extends 'base.html.twig' %}

{% block title %}Dashboard Workflows — Durable{% endblock %}

{% block body %}
<div class="container ds-page">
    <div class="page-intro">
        <h1>Workflow Dashboard</h1>
        <p>Vue de suivi simplifiee inspiree de Temporal UI, avec filtres et details d'execution.</p>
    </div>

    <section class="ds-kpi-grid" aria-label="Indicateurs workflows">
        <article class="ds-kpi">
            <span class="ds-kpi__label">Total</span>
            <strong class="ds-kpi__value">{{ kpis.total }}</strong>
        </article>
        <article class="ds-kpi">
            <span class="ds-kpi__label">Running</span>
            <strong class="ds-kpi__value">{{ kpis.running }}</strong>
        </article>
        <article class="ds-kpi">
            <span class="ds-kpi__label">Completed</span>
            <strong class="ds-kpi__value">{{ kpis.completed }}</strong>
        </article>
        <article class="ds-kpi">
            <span class="ds-kpi__label">Failed</span>
            <strong class="ds-kpi__value">{{ kpis.failed }}</strong>
        </article>
    </section>

    <form class="ds-filters" method="get" action="{{ path('app_dashboard') }}">
        <div>
            <label for="filter-q">Recherche</label>
            <input id="filter-q" class="ds-input" type="search" name="q" value="{{ query }}" placeholder="run id, workflow, queue">
        </div>
        <div>
            <label for="filter-status">Statut</label>
            <select id="filter-status" class="ds-select" name="status">
                <option value="all" {% if status == 'all' %}selected{% endif %}>Tous</option>
                <option value="running" {% if status == 'running' %}selected{% endif %}>Running</option>
                <option value="completed" {% if status == 'completed' %}selected{% endif %}>Completed</option>
                <option value="failed" {% if status == 'failed' %}selected{% endif %}>Failed</option>
            </select>
        </div>
        {% if selectedRunId %}
            <input type="hidden" name="run" value="{{ selectedRunId }}">
        {% endif %}
        <button type="submit" class="ds-btn ds-btn--primary">Filtrer</button>
    </form>

    <section class="ds-dashboard-split">
        <aside class="ds-dashboard-list" aria-label="Liste des workflows">
            <div class="ds-pagination">
                <span class="ds-pagination__label">Pagination par curseur ({{ pagination.pageSize }} par page)</span>
                <span class="ds-pagination__cursor">Curseur courant: <code>{{ pagination.cursorHint }}</code>{% if pagination.nextCursorHint %} · suivant: <code>{{ pagination.nextCursorHint }}</code>{% endif %}</span>
                <div class="hstack">
                    {% if pagination.hasPrevious %}
                        <a class="btn btn-ghost btn-sm" href="{{ path('app_dashboard', {
                            q: query,
                            status: status,
                            cursor: pagination.previousCursor,
                            stack: pagination.previousStack
                        }) }}">← Page precedente</a>
                    {% else %}
                        <span class="ds-pagination__disabled">← Page precedente</span>
                    {% endif %}
                    {% if pagination.hasNext %}
                        <a class="btn btn-ghost btn-sm" href="{{ path('app_dashboard', {
                            q: query,
                            status: status,
                            cursor: pagination.nextCursor,
                            stack: pagination.nextStack
                        }) }}">Page suivante →</a>
                    {% else %}
                        <span class="ds-pagination__disabled">Page suivante →</span>
                    {% endif %}
                </div>
            </div>

            {% if runs is empty %}
                <p class="ds-empty-state">Aucun workflow ne correspond aux filtres.</p>
            {% else %}
                {% for run in runs %}
                    <a class="ds-run-row{% if selectedRunId == run.runId %} is-active{% endif %}"
                       href="{{ path('app_dashboard', {
                           q: query,
                           status: status,
                           run: run.runId,
                           cursor: pagination.cursor,
                           stack: pagination.stack
                       }) }}">
                        <div class="ds-run-row__title">
                            <span>{{ run.workflowName }}</span>
                            <span class="ds-status-badge ds-status-badge--{{ run.status }}">{{ run.status|upper }}</span>
                        </div>
                        <div class="ds-run-row__meta">
                            <code class="ds-mono">{{ run.runId }}</code>
                            <span>{{ run.startedAt }}</span>
                            <span>Queue: {{ run.taskQueue }}</span>
                            <span>Duree: {{ run.duration }}</span>
                        </div>
                    </a>
                {% endfor %}
            {% endif %}
        </aside>

        <main class="ds-dashboard-detail" aria-label="Detail execution">
            {% if selectedRun %}
                <div class="result-card">
                    <div class="result-card-header">Execution Selectionnee</div>
                    <div class="result-card-body">
                        <dl class="meta-list">
                            <dt>Workflow</dt>
                            <dd>{{ selectedRun.workflowName }}</dd>
                            <dt>Run ID</dt>
                            <dd><code class="ds-mono">{{ selectedRun.runId }}</code></dd>
                            <dt>Status</dt>
                            <dd><span class="ds-status-badge ds-status-badge--{{ selectedRun.status }}">{{ selectedRun.status|upper }}</span></dd>
                            <dt>Started At</dt>
                            <dd>{{ selectedRun.startedAt }}</dd>
                            <dt>Task Queue</dt>
                            <dd>{{ selectedRun.taskQueue }}</dd>
                            <dt>Duration</dt>
                            <dd>{{ selectedRun.duration }}</dd>
                        </dl>
                    </div>
                </div>

                <div class="result-card">
                    <div class="result-card-header">Frise temporelle des evenements</div>
                    <div class="result-card-body">
                        <ol class="ds-timeline">
                            {% for event in selectedRun.events %}
                                <li class="ds-timeline__item">
                                    <span class="ds-timeline__dot"></span>
                                    <div class="ds-timeline__content">
                                        <div class="ds-timeline__meta">
                                            <span class="ds-event__time">{{ event.time }}</span>
                                            <span class="ds-event__id">#{{ event.eventId }}</span>
                                            <span class="ds-event-kind ds-event-kind--{{ event.category }}">{{ event.category|upper }}</span>
                                        </div>
                                        <code class="ds-mono">{{ event.type }}</code>
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    </div>
                </div>
            {% else %}
                <div class="result-card">
                    <div class="result-card-body">
                        <p class="ds-empty-state">Selectionnez une execution dans la liste pour voir le detail.</p>
                    </div>
                </div>
            {% endif %}
        </main>
    </section>
</div>
{% endblock %}
