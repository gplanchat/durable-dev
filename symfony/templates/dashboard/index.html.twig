{% extends 'base.html.twig' %}

{% block title %}Dashboard Workflows — Durable{% endblock %}

{% block body %}
<div class="container ds-page">
    <div class="page-intro">
        <h1>Workflow Dashboard</h1>
        <p>Suivez l'etat des executions en cours, identifiez rapidement les echecs et inspectez une execution en detail sans quitter la page.</p>
    </div>

    <section class="ds-kpi-grid" aria-label="Indicateurs workflows">
        <article class="ds-kpi">
            <span class="ds-kpi__label">Total</span>
            <strong class="ds-kpi__value">{{ kpis.total }}</strong>
        </article>
        <article class="ds-kpi">
            <span class="ds-kpi__label">Running</span>
            <strong class="ds-kpi__value">{{ kpis.running }}</strong>
        </article>
        <article class="ds-kpi">
            <span class="ds-kpi__label">Completed</span>
            <strong class="ds-kpi__value">{{ kpis.completed }}</strong>
        </article>
        <article class="ds-kpi">
            <span class="ds-kpi__label">Failed</span>
            <strong class="ds-kpi__value">{{ kpis.failed }}</strong>
        </article>
    </section>

    <form class="ds-filters" method="get" action="{{ path('app_dashboard') }}">
        <div>
            <label for="filter-q">Recherche</label>
            <input id="filter-q" class="ds-input" type="search" name="q" value="{{ query }}" placeholder="run id, workflow, queue">
        </div>
        <div>
            <label for="filter-status">Statut</label>
            <select id="filter-status" class="ds-select" name="status">
                <option value="all" {% if status == 'all' %}selected{% endif %}>Tous</option>
                <option value="running" {% if status == 'running' %}selected{% endif %}>Running</option>
                <option value="completed" {% if status == 'completed' %}selected{% endif %}>Completed</option>
                <option value="failed" {% if status == 'failed' %}selected{% endif %}>Failed</option>
            </select>
        </div>
        {% if selectedRunId %}
            <input type="hidden" name="run" value="{{ selectedRunId }}">
        {% endif %}
        {% if pagination.cursor %}
            <input type="hidden" name="cursor" value="{{ pagination.cursor }}">
        {% endif %}
        {% if pagination.stack %}
            <input type="hidden" name="stack" value="{{ pagination.stack }}">
        {% endif %}
        <input type="hidden" name="zoom" value="{{ timelineControls.zoom }}">
        {% for kind in timelineControls.visibleKinds %}
            <input type="hidden" name="kinds[]" value="{{ kind }}">
        {% endfor %}
        <button type="submit" class="ds-btn ds-btn--primary">Filtrer</button>
    </form>

    <section class="ds-dashboard-split">
        <aside class="ds-dashboard-list" aria-label="Liste des workflows">
            <div class="ds-pagination">
                <span class="ds-pagination__label">Navigation des executions</span>
                <span class="ds-pagination__cursor">Affichage de {{ runs|length }} execution{{ runs|length > 1 ? 's' : '' }} (max {{ pagination.pageSize }} par page)</span>
                <div class="hstack">
                    {% if pagination.hasPrevious %}
                        <a class="btn btn-ghost btn-sm" href="{{ path('app_dashboard', {
                            q: query,
                            status: status,
                            cursor: pagination.previousCursor,
                            stack: pagination.previousStack,
                            zoom: timelineControls.zoom,
                            kinds: timelineControls.visibleKinds
                        }) }}">← Page precedente</a>
                    {% else %}
                        <span class="ds-pagination__disabled">← Page precedente</span>
                    {% endif %}
                    {% if pagination.hasNext %}
                        <a class="btn btn-ghost btn-sm" href="{{ path('app_dashboard', {
                            q: query,
                            status: status,
                            cursor: pagination.nextCursor,
                            stack: pagination.nextStack,
                            zoom: timelineControls.zoom,
                            kinds: timelineControls.visibleKinds
                        }) }}">Page suivante →</a>
                    {% else %}
                        <span class="ds-pagination__disabled">Page suivante →</span>
                    {% endif %}
                </div>
            </div>

            {% if runs is empty %}
                <p class="ds-empty-state">Aucun workflow ne correspond aux filtres.</p>
            {% else %}
                {% for run in runs %}
                    <a class="ds-run-row{% if selectedRunId == run.runId %} is-active{% endif %}"
                       href="{{ path('app_dashboard', {
                           q: query,
                           status: status,
                           run: run.runId,
                           cursor: pagination.cursor,
                           stack: pagination.stack,
                           zoom: timelineControls.zoom,
                           kinds: timelineControls.visibleKinds
                       }) }}">
                        <div class="ds-run-row__title">
                            <span>{{ run.workflowName }}</span>
                            <span class="ds-status-badge ds-status-badge--{{ run.status }}">{{ run.status|upper }}</span>
                        </div>
                        <div class="ds-run-row__meta">
                            <code class="ds-mono">{{ run.runId }}</code>
                            <span>{{ run.startedAt }}</span>
                            <span>Queue: {{ run.taskQueue }}</span>
                            <span>Duree: {{ run.duration }}</span>
                        </div>
                    </a>
                {% endfor %}
            {% endif %}
        </aside>

        <main class="ds-dashboard-detail" aria-label="Detail execution">
            {% if selectedRun %}
                <div class="result-card">
                    <div class="result-card-header">Execution Selectionnee</div>
                    <div class="result-card-body">
                        <dl class="meta-list">
                            <dt>Workflow</dt>
                            <dd>{{ selectedRun.workflowName }}</dd>
                            <dt>Run ID</dt>
                            <dd><code class="ds-mono">{{ selectedRun.runId }}</code></dd>
                            <dt>Status</dt>
                            <dd><span class="ds-status-badge ds-status-badge--{{ selectedRun.status }}">{{ selectedRun.status|upper }}</span></dd>
                            <dt>Started At</dt>
                            <dd>{{ selectedRun.startedAt }}</dd>
                            <dt>Task Queue</dt>
                            <dd>{{ selectedRun.taskQueue }}</dd>
                            <dt>Duration</dt>
                            <dd>{{ selectedRun.duration }}</dd>
                        </dl>
                    </div>
                </div>

                <div class="result-card">
                    <div class="result-card-header">Frise temporelle</div>
                    <div class="result-card-body">
                        <div class="ds-gantt-controls">
                            <div class="ds-gantt-controls__zoom">
                                <span class="ds-gantt-controls__label">Zoom</span>
                                {% for zoomLevel in timelineControls.availableZooms %}
                                    <a class="btn btn-ghost btn-sm{% if timelineControls.zoom == zoomLevel %} is-active{% endif %}"
                                       href="{{ path('app_dashboard', {
                                           q: query,
                                           status: status,
                                           run: selectedRun.runId,
                                           cursor: pagination.cursor,
                                           stack: pagination.stack,
                                           zoom: zoomLevel,
                                           kinds: timelineControls.visibleKinds
                                       }) }}">{{ zoomLevel|upper }}</a>
                                {% endfor %}
                            </div>
                            <form method="get" action="{{ path('app_dashboard') }}" class="ds-gantt-controls__kinds">
                                <input type="hidden" name="q" value="{{ query }}">
                                <input type="hidden" name="status" value="{{ status }}">
                                <input type="hidden" name="run" value="{{ selectedRun.runId }}">
                                <input type="hidden" name="cursor" value="{{ pagination.cursor }}">
                                <input type="hidden" name="stack" value="{{ pagination.stack }}">
                                <input type="hidden" name="zoom" value="{{ timelineControls.zoom }}">
                                <span class="ds-gantt-controls__label">Lignes</span>
                                {% for kind in timelineControls.availableKinds %}
                                    <label class="ds-kind-toggle">
                                        <input type="checkbox" name="kinds[]" value="{{ kind }}" {% if kind in timelineControls.visibleKinds %}checked{% endif %}>
                                        <span>{{ kind|upper }}</span>
                                    </label>
                                {% endfor %}
                                <button type="submit" class="btn btn-ghost btn-sm">Appliquer</button>
                            </form>
                        </div>

                        {% if selectedRun.timeline is defined and selectedRun.timeline.lanes is not empty %}
                            <div class="ds-gantt">
                                <div class="ds-gantt__legend" aria-label="Legende de la frise">
                                    <span class="ds-gantt__legend-item"><span class="ds-gantt__legend-dot ds-gantt__legend-dot--execution"></span>Execution</span>
                                    <span class="ds-gantt__legend-item"><span class="ds-gantt__legend-dot ds-gantt__legend-dot--activity"></span>Activity</span>
                                    <span class="ds-gantt__legend-item"><span class="ds-gantt__legend-dot ds-gantt__legend-dot--signal"></span>Signal</span>
                                    <span class="ds-gantt__legend-item"><span class="ds-gantt__legend-dot ds-gantt__legend-dot--query"></span>Query</span>
                                    <span class="ds-gantt__legend-item"><span class="ds-gantt__legend-dot ds-gantt__legend-dot--update"></span>Update</span>
                                </div>

                                <div class="ds-gantt__viewport">
                                    <div class="ds-gantt__canvas">
                                        <div class="ds-gantt__header">
                                            <span>{{ selectedRun.timeline.startTime }}</span>
                                            <span>{{ selectedRun.timeline.endTime }}</span>
                                        </div>
                                <div class="ds-gantt__window-info">
                                    Fenetre active: <code>{{ selectedRun.timeline.startTime }} → {{ selectedRun.timeline.endTime }}</code>
                                    · Duree visible: <code>{{ selectedRun.timeline.windowDurationLabel }}</code>
                                </div>
                                        {% for lane in selectedRun.timeline.lanes %}
                                            <div class="ds-gantt__lane">
                                                <div class="ds-gantt__lane-label">{{ lane.label }}</div>
                                                <div class="ds-gantt__track">
                                                    <span class="ds-gantt__bar ds-gantt__bar--{{ lane.kind }}"
                                                          style="left: {{ lane.startPercent }}%; width: {{ lane.widthPercent }}%;"
                                                  title="Workflow: {{ selectedRun.workflowName }}&#10;Run ID: {{ selectedRun.runId }}&#10;Statut: {{ selectedRun.status|upper }}&#10;Ligne: {{ lane.label }}&#10;Type: {{ lane.kind|upper }}&#10;Debut: {{ lane.startTime }}&#10;Fin: {{ lane.endTime }}"></span>
                                                </div>
                                                <div class="ds-gantt__lane-time">{{ lane.startTime }} → {{ lane.endTime }}</div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <p class="ds-empty-state">Aucune donnee temporelle disponible pour cette execution.</p>
                        {% endif %}
                    </div>
                </div>

                <div class="result-card">
                    <div class="result-card-header">Historique des evenements</div>
                    <div class="result-card-body">
                        <ol class="ds-timeline">
                            {% for event in selectedRun.events %}
                                <li class="ds-timeline__item">
                                    <span class="ds-timeline__dot"></span>
                                    <div class="ds-timeline__content">
                                        <div class="ds-timeline__meta">
                                            <span class="ds-event__time">{{ event.time }}</span>
                                            <span class="ds-event__id">#{{ event.eventId }}</span>
                                            <span class="ds-event-kind ds-event-kind--{{ event.category }}">{{ event.category|upper }}</span>
                                        </div>
                                        <code class="ds-mono">{{ event.type }}</code>
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    </div>
                </div>
            {% else %}
                <div class="result-card">
                    <div class="result-card-body">
                        <p class="ds-empty-state">Selectionnez une execution dans la liste pour voir le detail.</p>
                    </div>
                </div>
            {% endif %}
        </main>
    </section>
</div>
{% endblock %}
